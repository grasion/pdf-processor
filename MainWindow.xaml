<Window x:Class="PDFProcessor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PDF 통합 처리기 v1.0.7 - 분할 &amp; 병합 &amp; 변환 &amp; OCR" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 메뉴 바 -->
        <Menu Grid.Row="0" Background="#F5F5F5">
            <MenuItem Header="도움말">
                <MenuItem Header="업데이트 확인" Click="CheckUpdate_Click"/>
                <Separator/>
                <MenuItem Header="프로그램 정보" Click="ShowAbout_Click"/>
            </MenuItem>
        </Menu>
        
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="10">
            <!-- PDF 분할 탭 -->
            <TabItem Header="PDF 분할">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" MinWidth="300" MaxWidth="400"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 좌측 컨트롤 -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0"
                              AllowDrop="True"
                              PreviewDragEnter="SplitDropZone_DragEnter"
                              PreviewDragOver="SplitDropZone_DragOver"
                              PreviewDrop="SplitDropZone_Drop">
                        <!-- 파일 선택 -->
                        <GroupBox Header="PDF 파일 선택" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="SplitFileLabel" Text="선택된 파일: 없음" Margin="5" TextWrapping="Wrap"/>
                                <Button Content="PDF 파일 선택" Click="SelectSplitFile_Click" Margin="5" Padding="10,5"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- 분할 옵션 -->
                        <GroupBox Header="분할 옵션" Margin="0,0,0,10">
                            <StackPanel>
                                <RadioButton x:Name="SplitModePages" Content="페이지 범위로 분할" IsChecked="True" 
                                           Margin="5" Checked="SplitMode_Changed"/>
                                <RadioButton x:Name="SplitModeIndividual" Content="각 페이지를 개별 파일로 분할" 
                                           Margin="5" Checked="SplitMode_Changed"/>
                                <RadioButton x:Name="SplitModeChunk" Content="페이지 단위로 분할" 
                                           Margin="5" Checked="SplitMode_Changed"/>
                                
                                <!-- 페이지 범위 -->
                                <StackPanel x:Name="SplitRangePanel" Orientation="Horizontal" Margin="5,10,5,5">
                                    <TextBlock Text="시작 페이지:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="SplitStartPage" Width="60" Margin="0,0,10,0"/>
                                    <TextBlock Text="끝 페이지:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="SplitEndPage" Width="60"/>
                                </StackPanel>
                                
                                <!-- 페이지 단위 -->
                                <StackPanel x:Name="SplitChunkPanel" Orientation="Horizontal" Margin="5" Visibility="Collapsed">
                                    <TextBlock Text="페이지 단위:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="SplitChunkSize" Width="60" Text="2" Margin="0,0,5,0"/>
                                    <TextBlock Text="페이지씩 분할" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- 출력 설정 -->
                        <GroupBox Header="출력 설정" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="SplitOutputLabel" Text="출력 폴더: 원본 파일과 같은 폴더" 
                                         Margin="5" TextWrapping="Wrap"/>
                                <Button Content="출력 폴더 선택" Click="SelectSplitOutputFolder_Click" 
                                      Margin="5" Padding="10,5"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- 실행 버튼 -->
                        <Button Content="PDF 분할 실행" Click="ExecuteSplit_Click" 
                              Margin="5,20,5,10" Padding="10,8" FontWeight="Bold" 
                              Background="#FF0078D7" Foreground="White"/>
                        
                        <!-- 진행률 -->
                        <ProgressBar x:Name="SplitProgressBar" Height="20" Margin="5,0,5,10"/>
                        <TextBlock x:Name="SplitStatusLabel" Text="PDF 파일을 선택하세요." 
                                 Margin="5" TextAlignment="Center" TextWrapping="Wrap"/>
                        
                        <!-- 블로그 배너 -->
                        <Border Background="#0078D7" BorderBrush="#005A9E" BorderThickness="2" 
                              CornerRadius="8" Margin="5,10,5,5" Padding="10" Cursor="Hand"
                              MouseLeftButtonDown="BlogBanner_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="개발자 블로그 보기" FontSize="14" FontWeight="Bold" 
                                         Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 좌측 하단 광고 영역 -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                              CornerRadius="8" Margin="5,5,5,0" Cursor="Hand"
                              MouseLeftButtonDown="TenpingAd_Click">
                            <Image x:Name="SplitAdImage" Stretch="Uniform" Margin="5"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- 우측 미리보기 -->
                    <GroupBox Grid.Column="1" Header="PDF 미리보기">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" 
                                            VerticalScrollBarVisibility="Auto"
                                            PreviewMouseWheel="SplitPreview_MouseWheel">
                                    <Image x:Name="SplitPreviewImage" Stretch="Uniform"/>
                                </ScrollViewer>
                                
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                    <Button Content="◀ 이전" Click="SplitPrevPage_Click" Margin="0,0,5,0" Padding="10,5"/>
                                    <TextBlock x:Name="SplitPageLabel" Text="페이지: 0/0" 
                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <Button Content="다음 ▶" Click="SplitNextPage_Click" Padding="10,5"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- 우측 페이지 썸네일 -->
                            <Border Grid.Column="1" Background="#FAFAFA" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ListBox x:Name="SplitPageThumbnailList" 
                                           Background="Transparent" BorderThickness="0"
                                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                           SelectionChanged="SplitPageThumbnail_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="3" Padding="3" Background="White">
                                                    <StackPanel>
                                                        <Image Source="{Binding Thumbnail}" Width="120" Height="160" Stretch="Uniform" Margin="0,0,0,3"/>
                                                        <TextBlock Text="{Binding PageLabel}" FontSize="9" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
            
            <!-- PDF 병합 탭 -->
            <TabItem Header="PDF 병합">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" MinWidth="300" MaxWidth="400"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 좌측 컨트롤 -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0"
                              AllowDrop="True"
                              PreviewDragEnter="MergeDropZone_DragEnter"
                              PreviewDragOver="MergeDropZone_DragOver"
                              PreviewDrop="MergeDropZone_Drop">
                        <!-- 파일 목록 -->
                        <GroupBox Header="파일 목록" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Background="LightGray" BorderBrush="Gray" 
                                      BorderThickness="1" Padding="10" Margin="5">
                                    <TextBlock Text="PDF/이미지 파일을 드래그하거나 추가 버튼 클릭" TextAlignment="Center"/>
                                </Border>
                                
                                <ListBox x:Name="MergeFileList" Grid.Row="1" Height="150" Margin="5"
                                       SelectionChanged="MergeFileList_SelectionChanged"/>
                                
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
                                    <Button Content="추가" Click="AddMergeFiles_Click" Width="60" Margin="0,0,5,0"/>
                                    <Button Content="↑" Click="MoveUp_Click" Width="30" Margin="0,0,5,0"/>
                                    <Button Content="↓" Click="MoveDown_Click" Width="30" Margin="0,0,5,0"/>
                                    <Button Content="제거" Click="RemoveMergeFile_Click" Width="60" Margin="0,0,5,0"/>
                                    <Button Content="전체삭제" Click="ClearMergeFiles_Click" Width="70"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                        
                        <!-- 설정 -->
                        <GroupBox Header="설정" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="파일명:" 
                                         VerticalAlignment="Center" Margin="5"/>
                                <TextBox x:Name="MergeFileName" Grid.Row="0" Grid.Column="1" 
                                       Grid.ColumnSpan="2" Margin="5"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="위치:" 
                                         VerticalAlignment="Center" Margin="5"/>
                                <TextBox x:Name="MergeSavePath" Grid.Row="1" Grid.Column="1" 
                                       Margin="5" IsReadOnly="True"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="..." 
                                      Click="BrowseMergeSavePath_Click" Width="30" Margin="5"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="크기:" 
                                         VerticalAlignment="Center" Margin="5"/>
                                <ComboBox x:Name="MergePageSize" Grid.Row="2" Grid.Column="1" 
                                        Margin="5" SelectedIndex="0">
                                    <ComboBoxItem Content="A4"/>
                                    <ComboBoxItem Content="A3"/>
                                    <ComboBoxItem Content="A5"/>
                                    <ComboBoxItem Content="Letter"/>
                                    <ComboBoxItem Content="Legal"/>
                                    <ComboBoxItem Content="원본"/>
                                </ComboBox>
                                <ComboBox x:Name="MergePageOrientation" Grid.Row="2" Grid.Column="2" 
                                        Width="80" Margin="5" SelectedIndex="0">
                                    <ComboBoxItem Content="세로"/>
                                    <ComboBoxItem Content="가로"/>
                                    <ComboBoxItem Content="원본"/>
                                </ComboBox>
                            </Grid>
                        </GroupBox>
                        
                        <!-- 실행 버튼 -->
                        <Button Content="PDF 병합 실행" Click="ExecuteMerge_Click" 
                              Margin="5,20,5,10" Padding="10,8" FontWeight="Bold" 
                              Background="#FF0078D7" Foreground="White"/>
                        
                        <!-- 진행률 -->
                        <ProgressBar x:Name="MergeProgressBar" Height="20" Margin="5,0,5,10"/>
                        <TextBlock x:Name="MergeStatusLabel" Text="병합할 PDF 파일들을 추가하세요." 
                                 Margin="5" TextAlignment="Center" TextWrapping="Wrap"/>
                        
                        <!-- 블로그 배너 -->
                        <Border Background="#0078D7" BorderBrush="#005A9E" BorderThickness="2" 
                              CornerRadius="8" Margin="5,10,5,5" Padding="10" Cursor="Hand"
                              MouseLeftButtonDown="BlogBanner_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="개발자 블로그 보기" FontSize="14" FontWeight="Bold" 
                                         Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 좌측 하단 광고 영역 -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                              CornerRadius="8" Margin="5,5,5,0" Cursor="Hand"
                              MouseLeftButtonDown="TenpingAd_Click">
                            <Image x:Name="MergeAdImage" Stretch="Uniform" Margin="5"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- 우측 미리보기 -->
                    <GroupBox Grid.Column="1" Header="병합 미리보기">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 페이지 정보 -->
                                <Border Grid.Row="0" Background="#F0F0F0" Padding="10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock x:Name="MergePageInfo" Text="페이지: 0 / 0" FontWeight="Bold" Margin="0,0,20,0"/>
                                        <TextBlock Text="마우스 휠로 페이지 이동" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- 미리보기 이미지 (스크롤 가능) -->
                                <Border Grid.Row="1" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Margin="5">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                                PreviewMouseWheel="MergePreview_MouseWheel">
                                        <Image x:Name="MergePreviewImage" Stretch="Uniform"/>
                                    </ScrollViewer>
                                </Border>
                                
                                <!-- 회전 컨트롤 -->
                                <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <TextBlock x:Name="RotationModeLabel" Text="현재 페이지 회전" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                                            <Button Content="↶ 90° 왼쪽" Click="RotateLeft_Click" Width="100" Margin="5,0" Padding="5"/>
                                            <Button Content="↷ 90° 오른쪽" Click="RotateRight_Click" Width="100" Margin="5,0" Padding="5"/>
                                            <Button Content="↻ 180°" Click="Rotate180_Click" Width="80" Margin="5,0" Padding="5"/>
                                        </StackPanel>
                                        <TextBlock x:Name="RotationStatusLabel" Text="" HorizontalAlignment="Center" Foreground="#0078D7" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            
                            <!-- 우측 페이지 리스트 -->
                            <Border Grid.Column="1" Background="#FAFAFA" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- 헤더 -->
                                    <Border Grid.Row="0" Background="#E0E0E0" Padding="10,8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                                        <TextBlock Text="페이지 목록" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    
                                    <!-- 페이지 썸네일 리스트 -->
                                    <ListBox x:Name="MergePageThumbnailList" Grid.Row="1" 
                                           Background="Transparent" BorderThickness="0"
                                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                           SelectionChanged="MergePageThumbnail_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="5" Padding="5" Background="White">
                                                    <StackPanel>
                                                        <CheckBox Content="" Tag="{Binding PageIndex}" 
                                                                Checked="PageCheckBox_Changed" Unchecked="PageCheckBox_Changed"
                                                                Margin="0,0,0,5"/>
                                                        <Image Source="{Binding Thumbnail}" Width="150" Height="200" Stretch="Uniform" Margin="0,0,0,5"/>
                                                        <TextBlock Text="{Binding PageLabel}" FontSize="10" HorizontalAlignment="Center" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding RotationInfo}" FontSize="9" HorizontalAlignment="Center" Foreground="Gray"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    
                                    <!-- 하단 버튼 -->
                                    <Border Grid.Row="2" Background="#E0E0E0" Padding="5" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
                                        <StackPanel>
                                            <Button Content="전체 선택" Click="SelectAllPages_Click" Margin="5" Padding="5"/>
                                            <Button Content="선택 해제" Click="DeselectAllPages_Click" Margin="5" Padding="5"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
            
            <!-- PDF → 이미지 변환 탭 -->
            <TabItem Header="PDF → 이미지">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" MinWidth="300" MaxWidth="400"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 좌측 컨트롤 -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0"
                              AllowDrop="True"
                              PreviewDragEnter="ConvertDropZone_DragEnter"
                              PreviewDragOver="ConvertDropZone_DragOver"
                              PreviewDrop="ConvertDropZone_Drop">
                        <!-- 파일 선택 -->
                        <GroupBox Header="PDF 파일 선택" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="ConvertFileLabel" Text="선택된 파일: 없음" 
                                         Margin="5" TextWrapping="Wrap"/>
                                <Button Content="PDF 파일 선택" Click="SelectConvertFile_Click" 
                                      Margin="5" Padding="10,5"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- 변환 옵션 -->
                        <GroupBox Header="변환 옵션" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="이미지 형식:" 
                                         VerticalAlignment="Center" Margin="5"/>
                                <ComboBox x:Name="ConvertImageFormat" Grid.Row="0" Grid.Column="1" 
                                        Margin="5" SelectedIndex="0">
                                    <ComboBoxItem Content="PNG"/>
                                    <ComboBoxItem Content="JPG"/>
                                    <ComboBoxItem Content="BMP"/>
                                    <ComboBoxItem Content="TIFF"/>
                                </ComboBox>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="해상도(DPI):" 
                                         VerticalAlignment="Center" Margin="5"/>
                                <ComboBox x:Name="ConvertDPI" Grid.Row="1" Grid.Column="1" 
                                        Margin="5" SelectedIndex="2">
                                    <ComboBoxItem Content="72"/>
                                    <ComboBoxItem Content="96"/>
                                    <ComboBoxItem Content="150"/>
                                    <ComboBoxItem Content="200"/>
                                    <ComboBoxItem Content="300"/>
                                    <ComboBoxItem Content="600"/>
                                </ComboBox>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="변환 페이지:" 
                                         VerticalAlignment="Center" Margin="5"/>
                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <RadioButton x:Name="ConvertModeAll" Content="모든 페이지" 
                                               IsChecked="True" Margin="5" Checked="ConvertMode_Changed"/>
                                    <RadioButton x:Name="ConvertModeRange" Content="페이지 범위 지정" 
                                               Margin="5" Checked="ConvertMode_Changed"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                                          x:Name="ConvertRangePanel" Orientation="Horizontal" 
                                          Margin="20,5,5,5" Visibility="Collapsed">
                                    <TextBlock Text="시작:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="ConvertStartPage" Width="60" Margin="0,0,10,0"/>
                                    <TextBlock Text="끝:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="ConvertEndPage" Width="60"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                        
                        <!-- 출력 설정 -->
                        <GroupBox Header="출력 설정" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="ConvertOutputLabel" Text="출력 폴더: 원본 파일과 같은 폴더" 
                                         Margin="5" TextWrapping="Wrap"/>
                                <Button Content="출력 폴더 선택" Click="SelectConvertOutputFolder_Click" 
                                      Margin="5" Padding="10,5"/>
                                
                                <TextBlock Text="파일명 패턴:" Margin="5,10,5,5"/>
                                <TextBox x:Name="ConvertFileNamePattern" Margin="5,0,5,5"/>
                                <TextBlock Text="filename: 원본 파일명, page: 페이지 번호" 
                                         Margin="5,0,5,5" FontSize="10" Foreground="Gray"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- 실행 버튼 -->
                        <Button Content="이미지로 변환" Click="ExecuteConvert_Click" 
                              Margin="5,20,5,10" Padding="10,8" FontWeight="Bold" 
                              Background="#FF0078D7" Foreground="White"/>
                        
                        <!-- 진행률 -->
                        <ProgressBar x:Name="ConvertProgressBar" Height="20" Margin="5,0,5,10"/>
                        <TextBlock x:Name="ConvertStatusLabel" Text="PDF 파일을 선택하세요." 
                                 Margin="5" TextAlignment="Center" TextWrapping="Wrap"/>
                        
                        <!-- 블로그 배너 -->
                        <Border Background="#0078D7" BorderBrush="#005A9E" BorderThickness="2" 
                              CornerRadius="8" Margin="5,10,5,5" Padding="10" Cursor="Hand"
                              MouseLeftButtonDown="BlogBanner_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="개발자 블로그 보기" FontSize="14" FontWeight="Bold" 
                                         Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 좌측 하단 광고 영역 -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                              CornerRadius="8" Margin="5,5,5,0" Cursor="Hand"
                              MouseLeftButtonDown="TenpingAd_Click">
                            <Image x:Name="ConvertAdImage" Stretch="Uniform" Margin="5"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- 우측 미리보기 -->
                    <GroupBox Grid.Column="1" Header="PDF 미리보기">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" 
                                            VerticalScrollBarVisibility="Auto"
                                            PreviewMouseWheel="ConvertPreview_MouseWheel">
                                    <Image x:Name="ConvertPreviewImage" Stretch="Uniform"/>
                                </ScrollViewer>
                                
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                    <Button Content="◀ 이전" Click="ConvertPrevPage_Click" Margin="0,0,5,0" Padding="10,5"/>
                                    <TextBlock x:Name="ConvertPageLabel" Text="페이지: 0/0" 
                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <Button Content="다음 ▶" Click="ConvertNextPage_Click" Padding="10,5"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- 우측 페이지 썸네일 -->
                            <Border Grid.Column="1" Background="#FAFAFA" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ListBox x:Name="ConvertPageThumbnailList" 
                                           Background="Transparent" BorderThickness="0"
                                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                           SelectionChanged="ConvertPageThumbnail_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="3" Padding="3" Background="White">
                                                    <StackPanel>
                                                        <Image Source="{Binding Thumbnail}" Width="120" Height="160" Stretch="Uniform" Margin="0,0,0,3"/>
                                                        <TextBlock Text="{Binding PageLabel}" FontSize="9" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <!-- OCR 텍스트 추출 탭 -->
            <TabItem Header="OCR 텍스트 추출">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" MinWidth="300" MaxWidth="400"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 좌측 컨트롤 -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0"
                              AllowDrop="True"
                              PreviewDragEnter="OcrDropZone_DragEnter"
                              PreviewDragOver="OcrDropZone_DragOver"
                              PreviewDrop="OcrDropZone_Drop">
                        <!-- 파일 선택 -->
                        <GroupBox Header="파일 선택 (PDF / 이미지)" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock x:Name="OcrFileLabel" Text="선택된 파일: 없음" Margin="5" TextWrapping="Wrap"/>
                                <Button Content="파일 선택" Click="SelectOcrFile_Click" Margin="5" Padding="10,5"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- OCR 옵션 -->
                        <GroupBox Header="OCR 옵션" Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="인식 언어:" 
                                         VerticalAlignment="Center" Margin="5"/>
                                <ComboBox x:Name="OcrLanguage" Grid.Row="0" Grid.Column="1" 
                                        Margin="5" SelectedIndex="0">
                                    <ComboBoxItem Content="한국어" Tag="korean"/>
                                    <ComboBoxItem Content="영어" Tag="english"/>
                                    <ComboBoxItem Content="한국어+영어" Tag="korean+english"/>
                                    <ComboBoxItem Content="일본어" Tag="japan"/>
                                    <ComboBoxItem Content="중국어" Tag="chinese"/>
                                </ComboBox>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="OCR 페이지:" 
                                         VerticalAlignment="Center" Margin="5"/>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <RadioButton x:Name="OcrModeAll" Content="모든 페이지" 
                                               IsChecked="True" Margin="5" Checked="OcrMode_Changed"/>
                                    <RadioButton x:Name="OcrModeCurrentPage" Content="현재 페이지만" 
                                               Margin="5" Checked="OcrMode_Changed"/>
                                    <RadioButton x:Name="OcrModeRange" Content="페이지 범위 지정" 
                                               Margin="5" Checked="OcrMode_Changed"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                          x:Name="OcrRangePanel" Orientation="Horizontal" 
                                          Margin="20,5,5,5" Visibility="Collapsed">
                                    <TextBlock Text="시작:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="OcrStartPage" Width="60" Margin="0,0,10,0"/>
                                    <TextBlock Text="끝:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="OcrEndPage" Width="60"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                        
                        <!-- 실행 버튼 -->
                        <Button Content="OCR 텍스트 추출" Click="ExecuteOcr_Click" 
                              Margin="5,10,5,5" Padding="10,8" FontWeight="Bold" 
                              Background="#FF0078D7" Foreground="White"/>
                        
                        <!-- 저장/복사 버튼 -->
                        <StackPanel Orientation="Horizontal" Margin="5,5,5,5">
                            <Button Content="결과 저장" Click="SaveOcrResult_Click" 
                                  Padding="10,6" Background="#FF4CAF50" Foreground="White" Margin="0,0,5,0"/>
                            <Button Content="클립보드 복사" Click="CopyOcrResult_Click" 
                                  Padding="10,6"/>
                        </StackPanel>
                        
                        <!-- AI 보정 -->
                        <GroupBox Header="AI 텍스트 보정 (로컬 LLM)" Margin="0,5,0,5">
                            <StackPanel>
                                <TextBlock Text="기본 모델: gemma-2-2b (최초 실행 시 자동 다운로드)" 
                                         Margin="5,5,5,2" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="5,2,5,5">
                                    <TextBox x:Name="AiModelPath" Width="220" IsReadOnly="True" 
                                           VerticalAlignment="Center" Margin="0,0,5,0"
                                           Text="자동 (gemma-2-2b-it-Q4_K_M)"/>
                                    <Button Content="..." Click="BrowseAiModel_Click" Width="30" Padding="5,2"
                                          ToolTip="커스텀 모델 선택"/>
                                </StackPanel>
                                <Button Content="🤖 AI 보정 실행" Click="ExecuteAiRefine_Click" 
                                      Margin="5" Padding="10,6" FontWeight="Bold"
                                      Background="#FF9C27B0" Foreground="White"/>
                                <TextBlock x:Name="AiStatusLabel" Text="" Margin="5,2,5,5" 
                                         FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- 진행률 -->
                        <ProgressBar x:Name="OcrProgressBar" Height="20" Margin="5,5,5,5"/>
                        <TextBlock x:Name="OcrStatusLabel" Text="PDF 또는 이미지 파일을 선택하세요." 
                                 Margin="5" TextAlignment="Center" TextWrapping="Wrap"/>
                        
                        <!-- 블로그 배너 -->
                        <Border Background="#0078D7" BorderBrush="#005A9E" BorderThickness="2" 
                              CornerRadius="8" Margin="5,10,5,5" Padding="10" Cursor="Hand"
                              MouseLeftButtonDown="BlogBanner_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="개발자 블로그 보기" FontSize="14" FontWeight="Bold" 
                                         Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 좌측 하단 광고 영역 -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                              CornerRadius="8" Margin="5,5,5,0" Cursor="Hand"
                              MouseLeftButtonDown="TenpingAd_Click">
                            <Image x:Name="OcrAdImage" Stretch="Uniform" Margin="5"/>
                        </Border>
                    </StackPanel>
                    </ScrollViewer>
                    
                    <!-- 우측: 미리보기(상단) + OCR 결과(하단) -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 상단: PDF/이미지 미리보기 -->
                        <GroupBox Grid.Row="0" Header="미리보기">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" 
                                                VerticalScrollBarVisibility="Auto"
                                                PreviewMouseWheel="OcrPreview_MouseWheel">
                                        <Image x:Name="OcrPreviewImage" Stretch="Uniform"/>
                                    </ScrollViewer>
                                    
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                        <Button Content="◀ 이전" Click="OcrPrevPage_Click" Margin="0,0,5,0" Padding="10,5"/>
                                        <TextBlock x:Name="OcrPageLabel" Text="페이지: 0/0" 
                                                 VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <Button Content="다음 ▶" Click="OcrNextPage_Click" Padding="10,5"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- 우측 페이지 썸네일 -->
                                <Border Grid.Column="1" Background="#FAFAFA" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ListBox x:Name="OcrPageThumbnailList" 
                                               Background="Transparent" BorderThickness="0"
                                               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                               SelectionChanged="OcrPageThumbnail_SelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="3" Padding="3" Background="White">
                                                        <StackPanel>
                                                            <Image Source="{Binding Thumbnail}" Width="120" Height="160" Stretch="Uniform" Margin="0,0,0,3"/>
                                                            <TextBlock Text="{Binding PageLabel}" FontSize="9" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </GroupBox>
                        
                        <!-- 구분선 (드래그로 크기 조절 가능) -->
                        <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="#CCCCCC"/>
                        
                        <!-- 하단: OCR 결과 텍스트 -->
                        <GroupBox Grid.Row="2" Header="OCR 추출 결과">
                            <TextBox x:Name="OcrResultTextBox" 
                                   AcceptsReturn="True" 
                                   TextWrapping="Wrap" 
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Auto"
                                   IsReadOnly="False"
                                   FontSize="13"
                                   FontFamily="맑은 고딕"/>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- 하단 커피 사주기 배너 (클릭 시 QR 팝업) -->
        <Border Grid.Row="2" x:Name="AdBorder" Background="#FFF8E1" BorderBrush="#FF6F00" BorderThickness="0,2,0,0" Height="80"
                MouseLeftButtonDown="CoffeeBanner_Click" Cursor="Hand">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="☕" FontSize="32" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="개발자에게 커피 사주기" 
                             FontSize="16" FontWeight="Bold" 
                             Foreground="#FF6F00" 
                             Margin="0,0,0,5"/>
                    <TextBlock Text="클릭하여 개발자에게 커피 한 잔 어때요?" 
                             FontSize="12" 
                             Foreground="#666"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
